@page
@model BuilderAssistantApi.Api.Areas.Identity.Pages.Account.VerifyOtpModel
@{
    ViewData["Title"] = "Verify Login Code";
}

<div class="auth-card card shadow-sm">
    <div class="card-body p-4">
        <h2 class="card-title mb-1">@ViewData["Title"]</h2>
        <p class="text-muted mb-4">Enter the code sent to <strong>@Model.Email</strong>.</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Otp" class="form-label"></label>
                <input asp-for="Input.Otp" class="form-control" autocomplete="one-time-code"
                       inputmode="numeric" autofocus placeholder="Enter code" />
                <span asp-validation-for="Input.Otp" class="text-danger"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary">Verify &amp; Log In</button>
            </div>
        </form>

        <div class="mt-3 text-center">
            <a asp-page="Login" asp-route-ReturnUrl="@Model.ReturnUrl" class="text-decoration-none small">
                &larr; Back to login
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
